{
  "name": "@rap/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply rap-db --local --config ../../apps/realtime/wrangler.jsonc",
    "db:migrate": "wrangler d1 migrations apply rap-db --remote --config ../../apps/realtime/wrangler.jsonc"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.4",
    "wrangler": "^4.98.0"
  }
}
