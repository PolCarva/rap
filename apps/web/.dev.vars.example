# Copiá este archivo a `.dev.vars` y completá los valores.
NEXTJS_ENV=development

# Transcripción cross-browser vía OpenRouter. Conseguí la key en:
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
# Opcional. Default: openai/gpt-4o-mini-transcribe
OPENROUTER_STT_MODEL=openai/gpt-4o-mini-transcribe

# Secreto para firmar sesiones (HMAC-SHA256). Generá uno con: openssl rand -hex 32
JWT_SECRET=cambia-esto-en-produccion

# Clave simple para /backoffice. Usala como password en la pantalla admin.
BACKOFFICE_PASSWORD=cambia-esto-tambien

# Opcional en dev; requerido para TURN real en producción.
# Se generan en Cloudflare Dashboard > Realtime > TURN.
TURN_KEY_ID=
TURN_KEY_API_TOKEN=
