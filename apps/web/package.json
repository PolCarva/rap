{
  "name": "@rap/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "node ../../scripts/lint-web.mjs",
    "typecheck": "tsc --noEmit",
    "deploy": "NEXT_PUBLIC_REALTIME_URL=wss://rap-realtime.raparena.workers.dev opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.9",
    "@rap/db": "*",
    "@rap/shared": "*",
    "next": "16.2.6",
    "react": "^19.1.7",
    "react-dom": "^19.1.7",
    "three": "^0.184.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.42",
    "@types/react": "^19.1.7",
    "@types/react-dom": "^19.1.7",
    "@types/three": "^0.184.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5.7.4",
    "wrangler": "^4.98.0"
  }
}
